# ============================================================
# 前端（Vite）环境变量
# ============================================================

# API 基础地址
VITE_API_BASE_URL=http://localhost:3000/api

# 应用标题
VITE_APP_TITLE=Kiro PJ

# ============================================================
# 后端（server/）环境变量
# ============================================================

# PostgreSQL 连接串（RDS 或本地开发库）
DATABASE_URL=postgres://user:password@localhost:5432/awsome_shop

# JWT 签名密钥（本地开发用，生产请用强随机值）
JWT_SECRET=change-me-in-production

# SES 发件身份（经 SES 验证的发件地址）
SES_FROM_ADDRESS=no-reply@example.com

# 允许注册的公司邮箱域名白名单（逗号分隔）
COMPANY_EMAIL_DOMAINS=example.com,corp.example.com

# 会话空闲过期时长（分钟）
SESSION_IDLE_MINUTES=60

# 用户上传图片的 S3 桶名
UPLOAD_BUCKET=awsome-shop-uploads-dev

# 图片公开访问基础地址（CloudFront /media 前缀）
MEDIA_BASE_URL=https://media.example.com

# 单张图片大小上限（字节，5MB）
MAX_IMAGE_BYTES=5242880

# 单件商品可关联图片数量上限
MAX_PRODUCT_IMAGES=5

# 初始管理员种子账号（部署初始化预置）
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-in-production
