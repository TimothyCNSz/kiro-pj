# ============================================================
# 环境变量示例。本地验证：复制为项目根 .env 后按需修改。
#   copy .env.example .env      (Windows CMD)
# 后端脚本用 `node --env-file=../.env` 读取本文件（需 Node.js >= 20.6）。
# 详细本地部署步骤见 LOCAL_DEV.md。
# ============================================================

# ------------------------------------------------------------
# 前端（Vite）
# ------------------------------------------------------------

# API 基础地址。两种方式二选一：
#   1) 直连后端（需后端开启 CORS，见下方 CORS_ALLOW_ORIGIN）：
#      VITE_API_BASE_URL=http://localhost:3000/api
#   2) 走 Vite 代理（相对路径，见 vite.config.ts 的 server.proxy）：
#      VITE_API_BASE_URL=/api
VITE_API_BASE_URL=http://localhost:3000/api

# 应用标题
VITE_APP_TITLE=AWSomeShop

# （可选）Vite 代理的后端端口，默认 3000，与后端 PORT 保持一致。
VITE_BACKEND_PORT=3000

# ------------------------------------------------------------
# 后端（server/）
# ------------------------------------------------------------

# 本地后端 HTTP 监听端口（start:local 使用）
PORT=3000

# PostgreSQL 连接串。
# 本地（docker-compose）：postgres://app:app@localhost:5432/awsome_shop
# 生产（RDS）：由部署脚本从 Secrets Manager 组装注入，不使用本文件。
DATABASE_URL=postgres://app:app@localhost:5432/awsome_shop

# 后端 CORS 放行来源。前端直连后端（VITE_API_BASE_URL 用绝对地址）时需开启：
#   * 放行任意来源（本地最简单）；或写具体来源如 http://localhost:5173。
#   留空则关闭 CORS（生产默认，前端与后端同源无需 CORS）。
CORS_ALLOW_ORIGIN=*

# JWT 签名密钥（本地随意；生产请用强随机值）
JWT_SECRET=local-dev-secret-change-me

# 发信方式：本地设为 console，把验证邮件（含验证链接/验证码）打印到后端控制台，
# 无需真实 SES。留空或非 console 时走真实 Amazon SES（本地通常没有凭证会失败）。
MAILER=console

# 验证链接基址：邮件里的验证链接指向前端验证页。本地设为前端 dev 地址，
# 控制台打印出的链接可直接在浏览器打开完成激活。
VERIFY_URL_BASE=http://localhost:5173/verify-email

# SES 发件身份（MAILER=console 时不使用；走真实 SES 时需为已验证发件地址）
SES_FROM_ADDRESS=no-reply@example.com

# 允许注册的公司邮箱域名白名单（逗号分隔）。本地含 example.com 便于用种子管理员，
# 以及 example-company.com 便于用演示员工账号 / 自助注册。
COMPANY_EMAIL_DOMAINS=example.com,example-company.com

# 会话空闲过期时长（分钟）
SESSION_IDLE_MINUTES=60

# 用户上传图片的 S3 桶名（本地无 S3；上传/头像功能本地不可用，见 LOCAL_DEV.md 已知限制）
UPLOAD_BUCKET=awsome-shop-uploads-dev

# 图片公开访问基础地址（后端在其后拼 /media/<objectKey>）
MEDIA_BASE_URL=http://localhost:5173

# 单张图片大小上限（字节，5MB）
MAX_IMAGE_BYTES=5242880

# 单件商品可关联图片数量上限
MAX_PRODUCT_IMAGES=5

# 初始管理员种子账号（seed 脚本读取；邮箱域名需在 COMPANY_EMAIL_DOMAINS 白名单内）
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin12345
